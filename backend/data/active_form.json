{
  "form_id": "bank_opening_form",
  "title": "Bank Account Opening Form",
  "fields": [
    {
      "field_id": "full_name",
      "label": "Full Name",
      "type": "text",
      "required": true,
      "validation_rules": {
        "min_length": 2,
        "max_length": 100
      }
    },
    {
      "field_id": "age",
      "label": "Age",
      "type": "number",
      "required": true,
      "validation_rules": {
        "min": 0,
        "max": 120,
        "conditional_rules": [
          {
            "if": {
              "field": "country",
              "equals": "India"
            },
            "then": {
              "min": 18
            }
          },
          {
            "if": {
              "field": "country",
              "equals": "China"
            },
            "then": {
              "min": 16
            }
          },
          {
            "if": {
              "field": "country",
              "equals": "Japan"
            },
            "then": {
              "min": 15
            }
          }
        ]
      }
    },
    {
      "field_id": "email",
      "label": "Email Address",
      "type": "text",
      "required": true,
      "validation_rules": {
        "regex": "^[\\w.-]+@[\\w.-]+\\.\\w{2,}$",
        "regex_description": "a valid email address"
      }
    },
    {
      "field_id": "phone",
      "label": "Phone Number",
      "type": "text",
      "required": true,
      "validation_rules": {
        "regex": "^\\+?[0-9]{7,15}$",
        "regex_description": "a valid phone number (7-15 digits, optional + prefix)"
      }
    },
    {
      "field_id": "country",
      "label": "Country",
      "type": "dropdown",
      "required": true,
