{
  "form_id": "job_application_form",
  "title": "Job Application Form",
  "fields": [
    {
      "field_id": "full_name",
      "label": "Full Name",
      "type": "text",
      "required": true,
      "validation_rules": {
        "min_length": 3,
        "max_length": 80
      }
    },
    {
      "field_id": "experience",
      "label": "Years of Experience",
      "type": "number",
      "required": true,
      "validation_rules": {
        "min": 0,
        "max": 50
      }
    },
    {
      "field_id": "job_role",
      "label": "Job Role",
      "type": "dropdown",
      "required": true,
      "dropdown_options": [
        {
          "value": "Frontend Developer",
          "meta": {
            "min_experience": 1
          }
        },
        {
          "value": "Backend Developer",
          "meta": {
            "min_experience": 2
          }
        },
        {
          "value": "DevOps Engineer",
          "meta": {
            "min_experience": 3
          }
        },
        {
          "value": "Intern",
          "meta": {
            "max_experience": 1
          }
        }
      ]
    },
    {
      "field_id": "skills",
      "label": "Skills",
      "type": "multi_select",
      "required": true,
      "dropdown_options": [
        {
          "value": "JavaScript"
        },
        {
          "value": "React"
        },
        {
          "value": "Node.js"
        },
        {
          "value": "Docker"
        },
        {
          "value": "AWS"
        }
      ]
    },
    {
      "field_id": "preferred_location",
      "label": "Preferred Work Location",
      "type": "dropdown",
      "required": true,
      "dropdown_options": [
        {
          "value": "Remote"
        },
        {
          "value": "India",
          "children": {
            "field_id": "city",
            "options": [
              {
                "value": "Bangalore"
              },
              {
                "value": "Hyderabad"
              },
              {
                "value": "Kochi"
              }
            ]
          }
        },
        {
          "value": "USA",
          "children": {
            "field_id": "city",
            "options": [
              {
                "value": "New York"
              },
              {
                "value": "San Francisco"
              }
            ]
          }
        }
      ]
    },
    {
      "field_id": "city",
      "label": "City",
      "type": "dropdown",
      "required": false,
      "parent_field_id": "preferred_location",
      "dropdown_options": []
    },
    {
      "field_id": "expected_salary",
      "label": "Expected Salary (USD)",
      "type": "number",
      "required": true,
      "validation_rules": {
        "min": 1000,
        "max": 1000000
      },
      "conditional_rules": [
        {
          "if": {
            "field": "job_role",
            "equals": "Intern"
          },
          "then": {
            "max": 2000
          }
        }
      ]
    },
    {
      "field_id": "availability",
      "label": "Availability",
      "type": "dropdown",
      "required": true,
      "dropdown_options": [
        {
          "value": "Immediate"
        },
        {
          "value": "15 Days"
        },
        {
          "value": "30 Days"
        }
      ]
    },
    {
      "field_id": "portfolio_url",
      "label": "Portfolio URL",
      "type": "text",
      "required": false,
      "validation_rules": {
        "regex": "^(https?:\\/\\/)?([\\w.-]+)\\.([a-z\\.]{2,6})([\\/\\w .-]*)*\\/?$",
        "regex_description": "a valid URL"
      },
      "conditional_rules": [
        {
          "if": {
            "field": "job_role",
            "equals": "Frontend Developer"
          },
          "then": {
            "required": true
          }
        }
      ]
    }
  ]
}