  {
  "form_id": "enterprise_onboarding_form",
  "title": "Enterprise Business & Compliance Onboarding",

  "system_prompt": "ABOUT THIS FORM: Enterprise onboarding form for companies including KYC, compliance, ownership structure, and financial profiling.\n\nFIELD GUIDE:\n- entity_type: Individual, Startup, SME, Enterprise\n- business_name: Legal entity name\n- registration_number: Government issued registration\n- incorporation_date: YYYY-MM-DD\n- country/state/city: Hierarchical location\n- directors: Dynamic list of directors\n- shareholders: Dynamic ownership structure\n- kyc_documents: Required based on entity_type\n- bank_details: Nested banking information\n- risk_profile: Auto-derived from inputs\n\nFUZZY RULES:\n1. 'pvt ltd', 'private limited' → normalize to 'Private Limited'\n2. Mixed input allowed → extract multiple values\n3. 'add director john 40 india' → dynamic insertion into directors[]\n4. Ownership parsing → 'john 60%, alice 40%' → shareholders array\n5. Misplaced inputs → map semantically\n\nTONE: Strict compliance officer tone.",

  "fields": [

    {
      "field_id": "entity_type",
      "label": "Entity Type",
      "type": "dropdown",
      "required": true,
      "dropdown_options": [
        { "value": "Individual" },
        { "value": "Startup" },
        { "value": "SME" },
        { "value": "Enterprise" }
      ]
    },

    {
      "field_id": "business_name",
      "label": "Business Name",
      "type": "text",
      "required": true
    },

    {
      "field_id": "registration_number",
      "label": "Registration Number",
      "type": "text",
      "required": true
    },

    {
      "field_id": "business_type",
      "label": "Business Type",
      "type": "dropdown",
      "required": true,
      "dropdown_options": [
        { "value": "Private Limited" },
        { "value": "Public Limited" },
        { "value": "Partnership" },
        { "value": "Sole Proprietorship" }
      ]
    },

    {
      "field_id": "location",
      "label": "Registered Location",
      "type": "group",
      "fields": [
        {
          "field_id": "country",
          "type": "dropdown",
          "required": true,
          "dropdown_options": [
            {
              "value": "India",
              "children": {
                "field_id": "state",
                "options": [
                  {
                    "value": "Kerala",
                    "children": {
                      "field_id": "city",
                      "options": [
                        { "value": "Kochi" },
                        { "value": "Trivandrum" }
                      ]
                    }
                  },
                  {
                    "value": "Karnataka",
                    "children": {
                      "field_id": "city",
                      "options": [
                        { "value": "Bangalore" }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "value": "USA",
              "children": {
                "field_id": "state",
                "options": [
                  {
                    "value": "California",
                    "children": {
                      "field_id": "city",
                      "options": [
                        { "value": "San Francisco" }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      ]
    },


    {
      "field_id": "bank_details",
      "label": "Bank Details",
      "type": "group",
      "fields": [
        {
          "field_id": "account_number",
          "type": "text",
          "required": true
        },
        {
          "field_id": "ifsc_code",
          "type": "text",
          "required": true,
          "validation_rules": {
            "regex": "^[A-Z]{4}0[A-Z0-9]{6}$"
          }
        },
        {
          "field_id": "swift_code",
          "type": "text",
          "required": false
        }
      ]
    },

    {
      "field_id": "kyc_documents",
      "label": "KYC Documents",
      "type": "array",
      "required": true,
      "fields": [
        {
          "field_id": "doc_type",
          "type": "dropdown",
          "dropdown_options": [
            { "value": "PAN" },
            { "value": "Aadhar" },
            { "value": "Passport" },
            { "value": "Certificate of Incorporation" }
          ]
        },
        {
          "field_id": "doc_number",
          "type": "text"
        }
      ]
    },

    {
      "field_id": "annual_revenue",
      "label": "Annual Revenue (USD)",
      "type": "number",
      "required": true
    },

    {
      "field_id": "risk_profile",
      "label": "Risk Profile",
      "type": "computed",
      "formula": "IF(annual_revenue > 10000000 OR any(directors.is_pep == true), 'HIGH', 'LOW')"
    },

    {
      "field_id": "compliance_flags",
      "label": "Compliance Flags",
      "type": "computed",
      "formula": "IF(sum(shareholders.ownership_percentage) != 100, 'INVALID_OWNERSHIP', 'OK')"
    }

  ]
}
]