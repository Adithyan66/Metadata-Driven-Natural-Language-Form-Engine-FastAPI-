  {
    "form_id": "job_application_form",
    "title": "Job Application Form",
    "system_prompt": "This is a job application form for a tech company. Roles include Frontend Developer, Backend Developer, DevOps Engineer, and Intern. Each role has experience requirements defined in metadata. Skills are multi-select — users can pick multiple. Preferred location can be Remote, India (with city options), or USA (with city options). City is only asked when location is not Remote. Interns have a salary cap of $2000. Frontend Developers must provide a portfolio URL. Use a casual, encouraging startup tone.",
    "fields": [
      {
        "field_id": "full_name",
        "label": "Full Name",
        "type": "text",
        "required": true,
        "validation_rules": {
          "min_length": 3,
          "max_length": 80
        }
      },
      {
        "field_id": "experience",
        "label": "Years of Experience",
        "type": "number",
        "required": true,
        "validation_rules": {
          "min": 0,
          "max": 50
        }
      },
      {
        "field_id": "job_role",
        "label": "Job Role",
        "type": "dropdown",
        "required": true,
        "dropdown_options": [
          {
            "value": "Frontend Developer",
            "meta": {
              "min_experience": 1
            }
          },
          {
            "value": "Backend Developer",
            "meta": {
              "min_experience": 2
            }
          },
          {
            "value": "DevOps Engineer",
            "meta": {
              "min_experience": 3
            }
          },
          {
            "value": "Intern",
            "meta": {
              "max_experience": 1
            }
          }
        ]
      },
      {
        "field_id": "preferred_location",
        "label": "Preferred Work Location",
        "type": "dropdown",
        "required": true,
        "dropdown_options": [
          {
            "value": "Remote"
          },
          {
            "value": "India",
            "children": {
              "field_id": "city",
              "options": [
                {
                  "value": "Bangalore"
                },
                {
                  "value": "Hyderabad"
                },
                {
                  "value": "Kochi"
                }
              ]
            }
          },
          {
            "value": "USA",
            "children": {
              "field_id": "city",
              "options": [
                {
                  "value": "New York"
                },
                {
                  "value": "San Francisco"
                }
              ]
            }
          }
        ]
      },
      {
        "field_id": "city",
        "label": "City",
        "type": "dropdown",
        "required": false,
        "active": false,
        "parent_field_id": "preferred_location",
        "dropdown_options": [],
        "conditional_rules": [
          {
            "if": {
              "field": "preferred_location",
              "operator": "not_equals",
              "value": "Remote"
            },
            "then": {
              "active": true,
              "required": true
            }
          }
        ]
      },
      {
        "field_id": "expected_salary",
        "label": "Expected Salary (USD)",
        "type": "number",
        "required": true,
        "validation_rules": {
          "min": 1000,
          "max": 1000000
        },
        "conditional_rules": [
          {
            "if": {
              "field": "job_role",
              "equals": "Intern"
            },
            "then": {
              "max": 2000
            }
          }
        ]
      },
      {
        "field_id": "availability",
        "label": "Availability",
        "type": "dropdown",
        "required": true,
        "dropdown_options": [
          {
            "value": "Immediate"
          },
          {
            "value": "15 Days"
          },
          {
            "value": "30 Days"
          }
        ]
      },
      {
        "field_id": "portfolio_url",
        "label": "Portfolio URL",
        "type": "text",
        "required": false,
        "validation_rules": {
          "regex": "^(https?:\\/\\/)?([\\w.-]+)\\.([a-z\\.]{2,6})([\\/\\w .-]*)*\\/?$",
          "regex_description": "a valid URL"
        },
        "conditional_rules": [
          {
            "if": {
              "field": "job_role",
              "equals": "Frontend Developer"
            },
            "then": {
              "required": true
            }
          }
        ]
      }
    ]
  },
  {
    "form_id": "job_application_form",
    "title": "Job Application Form",
    "system_prompt": "ABOUT THIS FORM: Job application form collecting candidate details, experience, and preferences.\n\nFIELD GUIDE:\n- candidate_name: Full name of applicant\n- dob: Date of birth in YYYY-MM-DD format\n- email: Valid email format\n- phone: 7-15 digits, optional + prefix\n- experience_years: Total years of experience\n- skills: Comma-separated skills\n- highest_qualification: Degree or certification\n- job_role: Desired role\n- preferred_location: Country → State → City hierarchy\n- expected_salary: Monthly salary expectation in USD\n- availability: Immediate, 15 Days, 30 Days, 60 Days\n- resume_link: URL to resume\n\nFUZZY MATCHING RULES:\n1. ROLE MATCHING: 'backend dev', 'backend developer' → 'Backend Engineer'\n2. LOCATION FIX: 'banglore' → 'Bangalore', 'delhii' → 'Delhi'\n3. EXPERIENCE EXTRACTION: '5 years exp' → experience_years=5\n4. MIXED INPUT: 'john 5 years india backend' → extract all relevant fields\n5. MISPLACED INPUT: Map semantically instead of rejecting\n\nTONE: Professional HR assistant.",
